# Points the dashboard at the API.
#
# NEXT_PUBLIC_* vars are baked in at BUILD time, not read at runtime —
# changing this requires `npm run build` again, not just a process restart.
#
# Local dev (API and dashboard on different ports):
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
#
# Single-origin deploy behind nginx (see infrastructure/nginx/slotwise.conf —
# API is proxied under /api/ and /webhooks/ on the same host as the dashboard):
# NEXT_PUBLIC_API_BASE_URL=
