# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# The API's own externally-reachable URL (no trailing slash). Required for
# Twilio webhook signature verification — Twilio signs requests against the
# exact URL it called, so this must match what's configured in the Twilio
# Console exactly (https://api.yourdomain.com in production; for local dev
# against a real WhatsApp number, this needs to be a tunnel URL like ngrok).
PUBLIC_BASE_URL=http://localhost:3001

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-32-chars-min

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://slotwise:slotwise@localhost:5432/slotwise

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Claude API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Notifications ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=
BREVO_API_KEY=
FROM_EMAIL=noreply@slotwise.app

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
